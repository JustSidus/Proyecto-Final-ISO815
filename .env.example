# ============================================================================
# Variables de Entorno para Django - Sistema de Compras UNAPEC
# ============================================================================
# 
# INSTRUCCIONES:
# 1. Copiar este archivo como `.env` en la raíz del proyecto
# 2. Configurar los valores según el entorno (desarrollo o producción)
# 3. Django leerá automáticamente estas variables cuando esté configurado
#
# ============================================================================

# ====================
# AMBIENTE (OBLIGATORIO)
# ====================
# local        → Modo desarrollo (DEBUG=True, ALLOWED_HOSTS flexible)
# production   → Modo producción en Azure (DEBUG=False, ALLOWED_HOSTS restringido)
DJANGO_ENV=local

# Puerto local por defecto para `python manage.py runserver`
# Evita choque con otras apps locales en 8000.
DJANGO_RUNSERVER_ADDRPORT=127.0.0.1:8010

# ====================
# CLAVE SECRETA (Obligatoria en producción)
# ====================
# En desarrollo Django usa la clave por defecto.
# En producción DEBES generar una nueva clave segura:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Luego pegarla aquí y subirla SOLO a Azure (nunca a Git)
# DJANGO_SECRET_KEY=tu-clave-secreta-aqui-muy-larga-y-aleatoria

# ====================
# HOST PERMITIDO (Opcional, solo en producción)
# ====================
# Si quieres un dominio personalizado en lugar de *.azurewebsites.net
# Ejemplo: miapp.azurewebsites.net
# DJANGO_ALLOWED_HOST=miapp.azurewebsites.net

# ====================
# INTEGRACION WS CONTABLE (Asientos)
# ====================
# Activa/desactiva el envio automatico al completar ordenes.
WS_CONTABLE_ENABLED=false

# URL base del proyecto contable externo.
# Si no defines puerto explícito, la integración intentará fallback a :3000 y :8080.
WS_CONTABLE_BASE_URL=http://151.242.194.24:3000

# Timeout de la llamada HTTP en segundos.
WS_CONTABLE_TIMEOUT=10

# IDs remotos que debe usar la integracion.
# Auxiliar recomendado para este modulo: Compras (id 7).
WS_CONTABLE_AUXILIAR_ID=7

# Mapeo de cuentas para el detalle del asiento remoto:
# Debito  -> Inventario/Banco segun tu plan de cuentas remoto
# Credito -> Cuentas por pagar proveedores
WS_CONTABLE_CUENTA_DEBITO_ID=2
WS_CONTABLE_CUENTA_CREDITO_ID=1
